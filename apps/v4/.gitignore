# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# generated preview server assets
/public/preview
/preview-server/dist

# generated content
.contentlayer
.content-collections
.source
.devtools

# generated registry output (rebuilt by registry:build on every deploy).
# index.json, default and new-york are NOT build outputs: index.json is a
# static contract older CLIs fetch, and default/new-york are frozen v3
# styles maintained by editing the JSON directly.
/public/r/styles/*
!/public/r/styles/index.json
!/public/r/styles/default/
!/public/r/styles/new-york/

# generated style sources (rebuilt by registry:build, or targeted via
# `pnpm registry:build --style all`). See styles/README.md.
/styles/*
!/styles/README.md

# [FORCE-UI-START] framework-port registry output (rebuilt by registry:build,
# dirName r-react/r-vue/r-svelte/r-ember in build-registry.mts). The generated
# per-style trees mirror /public/r/styles/* and are stripped for the same
# reason; colors/icons/index.json/config.json stay tracked like /public/r.
/public/r-react/styles/*
/public/r-vue/styles/*
/public/r-svelte/styles/*
/public/r-ember/styles/*
# [FORCE-UI-END]
